{
  "name": "@routr/extension-chrome",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox --mv3",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox --mv3",
    "build:all": "wxt build && wxt build --browser firefox --mv3",
    "typecheck": "wxt prepare && tsc --noEmit",
    "test": "vitest run",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox --mv3",
    "icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@routr/crypto": "workspace:*",
    "@routr/protocol": "workspace:*",
    "idb": "^8.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "@vitejs/plugin-react": "^4.5.1",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "vitest": "^2.1.4",
    "wxt": "^0.20.6"
  }
}
