{
  "name": "@routr/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node --import tsx src/main.ts",
    "build": "echo 'server uses tsx at runtime, no compile step'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.0.5",
    "@routr/crypto": "workspace:*",
    "@routr/protocol": "workspace:*",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.36.3",
    "hono": "^4.6.10",
    "pino": "^9.5.0",
    "valibot": "^0.42.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
